# Anthropic API (자동화 실행 엔진용)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6      # 비용 최적화 시 claude-haiku-4-5-20251001
MAX_TOKENS=2000
ENABLE_WEB_SEARCH=1                    # 브리핑류 자동화에 웹서치 허용

# 확장 패널 REST 인증 토큰 (길고 랜덤하게)
CLAUDE_PLUS_TOKEN=change-me-to-long-random-string

# ntfy 푸시 대상 (추측 불가능한 비밀 토픽 이름 권장)
NTFY_URL=https://ntfy.sh/your-secret-topic

# 기타
PORT=8787
CLAUDE_PLUS_DB=claude_plus.db
