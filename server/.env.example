# Anthropic API (automation execution engine)
# Your PAID key from console.anthropic.com (separate from your Claude subscription)
ANTHROPIC_API_KEY=sk-ant-...
# claude-haiku-4-5-20251001 is cheap and fine for notifications
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=2000
# 1 = allow web search for briefing-style automations
ENABLE_WEB_SEARCH=1

# Password the Chrome extension panel uses (make it long and random)
# e.g. run: openssl rand -hex 24
CLAUDE_PLUS_TOKEN=change-me-to-long-random-string

# ntfy push target (pick an unguessable topic name; leave blank for no push)
NTFY_URL=https://ntfy.sh/your-secret-topic

# Misc
PORT=8787
CLAUDE_PLUS_DB=claude_plus.db
